{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nausilus",
  "version": "0.0.1",
  "identifier": "com.nausilus.desktop",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "Nausilus",
        "width": 240,
        "height": 320,
        "resizable": true,
        "minWidth": 240,
        "minHeight": 320,
        "maxWidth": 960,
        "maxHeight": 1280,
        "fullscreen": false,
        "decorations": true
      }
    ]
  }
}